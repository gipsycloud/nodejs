<section class="section" id="github">
  <div class="container">
    <div class="section-heading text-center">
      <p class="section-subtitle">Proof of Work</p>
      <h6 class="section-title mb-4">GitHub Contributions</h6>
    </div>

    <% if (typeof githubError !== 'undefined' && githubError) { %>
      <div class="alert alert-warning" role="alert">
        <%- githubError %>
      </div>
    <% } else { %>
      <div class="github-panel">
        <div class="heatmap-container">
          <div class="month-labels">
            <% for (let i = 0; i < 53; i++) { %>
              <% const month = monthLabels.find(label => label.weekIndex === i); %>
              <div class="month-label"><%= month ? month.month : '' %></div>
            <% } %>
          </div>
          <div class="heatmap">
            <% contributionDays.forEach(day => { %>
              <div
                class="day contribution-<%= day.contributionCount === 0 ? 'none' : day.contributionCount < 3 ? 'low' : day.contributionCount < 5 ? 'medium' : day.contributionCount < 10 ? 'high' : 'very-high' %>"
                title="<%= day.date %>: <%= day.contributionCount %> contributions">
              </div>
            <% }) %>
          </div>
        </div>

        <div class="github-stats">
          <div class="stat-card">
            <span>Total Commits</span>
            <strong><%= totalCommits.toLocaleString() %></strong>
          </div>
          <div class="stat-card">
            <span>Total Contributions</span>
            <strong><%= totalContributions.toLocaleString() %></strong>
          </div>
        </div>
      </div>
    <% } %>
  </div>
</section>

